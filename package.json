{
  "name": "root",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/streamflow-finance/js-sdk.git"
  },
  "keywords": [
    "solana",
    "token",
    "vesting",
    "escrow",
    "stream",
    "spl",
    "anchor"
  ],
  "author": "Streamflow Labs Limited <legal@streamflowlabs.com>",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/streamflow-finance/js-sdk/issues"
  },
  "scripts": {
    "build": "lerna run build --ignore @streamflow/docs",
    "dev": "pnpm build && pnpm -r --stream --parallel --filter \"@streamflow/common\" --filter \"@streamflow/stream\" --filter \"@streamflow/staking\" --filter \"@streamflow/distributor\" run dev",
    "build-docs": "typedoc packages/stream/index.ts",
    "pack": "lerna run pack",
    "test": "lerna run test",
    "lint": "lerna run lint",
    "tsc:lint": "lerna run tsc:lint",
    "docs:build": "lerna exec -- typedoc",
    "validate-types": "lerna exec -- attw --pack --profile node16 .",
    "validate-packages": "lerna exec -- publint && pnpm validate-types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "version-all": "lerna version --force-publish --no-git-tag-version --no-push",
    "publish": "pnpm validate-packages && lerna publish from-package --yes --loglevel=verbose",
    "local-publish": "lerna publish --no-git-tag-version --no-push --registry=\"http://localhost:4873/\" from-package --yes",
    "local-unpublish": "lerna exec -- npm unpublish --registry=\"http://localhost:4873/\" \"\\${LERNA_PACKAGE_NAME}@\\$(npm view \\$LERNA_PACKAGE_NAME version)\"",
    "local-unpublish-all": "lerna exec -- npm unpublish -f --registry=\"http://localhost:4873/\" \"\\${LERNA_PACKAGE_NAME}\"",
    "prepare": "husky install",
    "convert-bn": "./scripts/convertBN.sh",
    "examples:verify": "pnpm --filter \"./examples/*\" run verify",
    "examples:install": "pnpm --filter \"./examples/*\" install",
    "examples:build": "pnpm --filter \"./examples/*\" --parallel run build",
    "examples": "pnpm examples:install && pnpm examples:build && pnpm examples:verify",
    "watch:docs": "typedoc --out dist/docs",
    "watch:docs:serve": "pnpx serve dist/docs -p 51921",
    "serve:docs": "pnpm run --stream \"/^watch:docs.*/\"",
    "watch:build-pack": "node scripts/watch-build-pack.cjs",
    "fumadocs:dev": "pnpm --filter @streamflow/docs dev",
    "fumadocs:build": "pnpm --filter @streamflow/docs generate-api && pnpm --filter @streamflow/docs build",
    "fumadocs:generate-api": "pnpm --filter @streamflow/docs generate-api"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.17.4",
    "@types/eslint": "^8.56.3",
    "@types/node": "^24.3.0",
    "chokidar": "4.0.3",
    "eslint": "^8.56.0",
    "eslint-import-resolver-typescript": "3.8.3",
    "husky": "^8.0.0",
    "lerna": "7.4.2",
    "lint-staged": "^13.1.0",
    "prettier": "^3.2.5",
    "publint": "0.3.8",
    "tsup": "^8.0.2",
    "typedoc": "0.27.8",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "version": "4.0.1",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs,cts,json,yml,yaml}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.15.0",
      "handlebars": ">=4.7.9",
      "lodash": ">=4.18.0",
      "cross-spawn": ">=7.0.5",
      "braces": ">=3.0.3",
      "flatted": ">=3.4.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "rollup": ">=4.59.0",
      "validator": ">=13.15.22",
      "tar": ">=7.5.11",
      "glob@7.1.4": "7.2.3"
    }
  }
}
